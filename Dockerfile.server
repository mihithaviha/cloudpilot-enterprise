FROM node:18-alpine

WORKDIR /app

# Copy root configurations and server folder
COPY package.json ./
COPY server/package*.json ./server/
RUN npm install --prefix server

COPY server/ ./server/

WORKDIR /app/server
RUN npm run build || true  # Build if there is a build script, or proceed

EXPOSE 5000

CMD ["npm", "run", "start"]
